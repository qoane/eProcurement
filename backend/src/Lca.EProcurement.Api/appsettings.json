{
  "ConnectionStrings": {
    "Default": "Server=localhost;Database=LcaEProcurement;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=true"
  },
  "Database": {
    "Provider": "SqlServer"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "ProcuraFlow",
    "Audience": "ProcuraFlow",
    "SigningKey": "ProcuraFlow development signing key - replace in production",
    "ExpiryMinutes": 120
  },
  "SmtpSettings": {
    "Host": "",
    "Port": 25,
    "UserName": "",
    "Password": "",
    "From": "no-reply@localhost",
    "EnableSsl": true,
    "IsEnabled": false
  },
  "SmsSettings": {
    "BaseUrl": "",
    "ApiKey": "bee-dev-secret-key",
    "ApiKeyHeaderName": "x-api-key",
    "AccountId": "",
    "ClientReferencePrefix": "LCA",
    "IsEnabled": false
  },
  "NotificationSettings": {
    "DefaultChannels": "InApp",
    "EnableInApp": true,
    "EnableEmail": false,
    "EnableSms": false
  },
  "SystemSettings": {
    "ApplicationName": "LCA eProcurement",
    "TenantName": "Lesotho Communications Authority",
    "DefaultPortalUrl": "http://localhost:5173",
    "SupportEmail": "support@example.test",
    "TimeZone": "Africa/Maseru"
  },
  "Storage": {
    "Documents": {
      "RootPath": "./App_Data/Documents"
    }
  },
  "Documents": {
    "StorageProvider": "LocalFileSystem",
    "MaxFileSizeMb": "50",
    "AllowedExtensions": ".pdf,.doc,.docx,.xls,.xlsx,.png,.jpg,.jpeg",
    "RequireVirusScan": "false",
    "AllowPublicDownloads": "true",
    "DefaultRetentionDays": "2555",
    "ArchiveAfterDays": "1825",
    "AllowSupplierDocumentDownload": "true",
    "AllowSealedBidDocumentDownloadBeforeOpening": "false"
  },
  "Operations": {
    "EnvironmentName": "Development",
    "PublicBaseUrl": "http://localhost:5000",
    "FrontendBaseUrl": "http://localhost:5173",
    "SlowRequestThresholdMs": 1000,
    "EnablePerformanceSampling": true,
    "PerformanceSamplingPercentage": 10,
    "MaxPageSize": 100,
    "ShowDetailedErrorsInDevelopment": true,
    "BackupEnabled": false,
    "BackupStorageLocation": "Configured by infrastructure",
    "BackupRetentionDays": 30,
    "RequireBackupBeforeMigration": false,
    "EnableSupportCases": true,
    "EnableHealthCheckAudit": true
  }
}
